# Testnet configuration — copy to .env.local to run Solana Token against Solana testnet.
# The connection guardrail (lib/solana/connection.ts) refuses mismatched
# network/RPC combinations at startup.

# ── Solana RPC ─────────────────────────────────────────────────────────────
# Helius has no testnet endpoint — use the public testnet RPC or your provider's.
SOLANA_RPC_URL=https://api.testnet.solana.com
NEXT_PUBLIC_RPC_URL=https://api.testnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=testnet

# ── Feature availability on testnet ────────────────────────────────────────
# Helius DAS (holder counts, wallet holdings enrichment) is mainnet/devnet only.
# On testnet the app automatically degrades: holdings fall back to plain RPC
# (no logos/symbols), holder counts show as null. Leave the key set or empty.
HELIUS_API_KEY=
# Birdeye has no testnet market data — price/volume/liquidity render as "—".
BIRDEYE_API_KEY=

# ── App URL ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Fee wallet (testnet keypair — NEVER a mainnet wallet) ──────────────────
FEE_WALLET_ADDRESS=

# ── IPFS (network-independent — same Pinata account works) ─────────────────
PINATA_JWT=

# ── Database (optional in test environments) ───────────────────────────────
# All DB paths degrade gracefully when unreachable: /api/confirm still
# verifies fees on-chain and returns recorded:false; list endpoints return [].
DATABASE_URL=postgresql://user:password@host:5432/dbname
PG_POOL_MAX=10

# ── Redis (optional — rate limiting fails open, caches no-op without it) ───
# For local testing without Redis:  node scripts/dev-redis.mjs
REDIS_URL=redis://localhost:6379

# ── Secrets ────────────────────────────────────────────────────────────────
WEBHOOK_AUTH_SECRET=
CRON_SECRET=
