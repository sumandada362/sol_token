# MAINNET configuration — copy to .env.local (or your host's env settings) to
# run FORGE against Solana mainnet-beta. Every transaction moves REAL SOL.
#
# The startup guardrail (lib/solana/connection.ts) refuses mismatched
# network/RPC combinations (e.g. mainnet-beta network with a devnet RPC).
#
# Pre-launch checklist (see docs/mainnet-readiness.md for the full version):
#   [ ] Fresh Helius API key (the old one was committed to git history — rotate it)
#   [ ] FEE_WALLET_ADDRESS is a hardware-wallet public key, private key never on a server
#   [ ] DATABASE_URL and REDIS_URL point at real managed instances (NOT optional on mainnet:
#       without Redis, rate limiting fails OPEN; without Postgres, fee events are not journaled)
#   [ ] WEBHOOK_AUTH_SECRET / CRON_SECRET freshly generated (openssl rand -hex 32)
#   [ ] Alerting on `recorded:false` responses from /api/confirm (see docs/runbooks/)

# ── Solana RPC ─────────────────────────────────────────────────────────────
# Server-side RPC — carries your API key, NEVER exposed to the browser.
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
# Browser wallet adapter RPC — VISIBLE to the browser. The public mainnet RPC
# (api.mainnet-beta.solana.com) heavily rate-limits and is not for production;
# use a provider endpoint safe to expose (domain-allowlisted key) or a dedicated
# public-tier key. Its origin is auto-added to the CSP connect-src at build time.
NEXT_PUBLIC_RPC_URL=https://your-rpc-provider.example/?api-key=PUBLIC_TIER_KEY
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta

# Extra hosts to allow in the CSP connect-src (space-separated), if your RPC
# provider uses a separate websocket host or you add other browser-side calls.
# Leave empty for Helius/Triton/rpcpool/*.solana.com (already allowed) or when
# NEXT_PUBLIC_RPC_URL alone is enough. Example:
#   CSP_CONNECT_SRC_EXTRA=wss://atlas-mainnet.example https://api.other.example
CSP_CONNECT_SRC_EXTRA=

# ── Data providers (full functionality on mainnet) ─────────────────────────
# Helius DAS — holder counts, enriched wallet holdings (logos/symbols).
HELIUS_API_KEY=YOUR_HELIUS_API_KEY
# Birdeye — price/volume/liquidity/market cap on token pages.
BIRDEYE_API_KEY=YOUR_BIRDEYE_API_KEY

# ── App URL ────────────────────────────────────────────────────────────────
# Full production origin — used for Helius webhook callbacks and OG/SEO URLs.
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ── Fee wallet ─────────────────────────────────────────────────────────────
# PUBLIC KEY ONLY. Private key lives in a hardware wallet, never on a server.
# Compromise runbook: docs/runbooks/fee-wallet-compromised.md
FEE_WALLET_ADDRESS=

# ── IPFS ───────────────────────────────────────────────────────────────────
PINATA_JWT=YOUR_PINATA_JWT

# ── Database (REQUIRED on mainnet) ─────────────────────────────────────────
# Fee accounting and token records. The app degrades gracefully without it,
# but on mainnet that means real fees go unjournaled (recorded:false).
#
# Self-hosted on this VPS: scripts/vps-bootstrap.sh creates a `forge` role + db
# and fills this line in automatically. Manual form (see deployment guide §4.7):
#   postgresql://forge:STRONG_PASSWORD@localhost:5432/forge
DATABASE_URL=postgresql://forge:STRONG_PASSWORD@localhost:5432/forge
PG_POOL_MAX=10

# ── Redis (REQUIRED on mainnet) ────────────────────────────────────────────
# Rate limiting fails OPEN without Redis — do not launch without it.
# Self-hosted on this VPS: vps-bootstrap.sh sets a password and fills this in.
#   redis://default:STRONG_PASSWORD@localhost:6379
REDIS_URL=redis://default:STRONG_PASSWORD@localhost:6379

# ── Secrets — generate fresh for production: openssl rand -hex 32 ──────────
WEBHOOK_AUTH_SECRET=
CRON_SECRET=
