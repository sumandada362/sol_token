# Copy to .env.local (and restart dev server) when running devnet tests.
# NEVER commit this file with real keys.
# All values below target DEVNET — zero real money involved.

# Devnet RPC (Helius free tier supports devnet)
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Helius API key — same key works for devnet and mainnet
HELIUS_API_KEY=YOUR_HELIUS_API_KEY

# Webhook secret — generate: openssl rand -hex 32
# Use a separate devnet webhook in the Helius dashboard
WEBHOOK_AUTH_SECRET=REPLACE_WITH_32_BYTE_HEX

# Dev fee wallet — an ephemeral wallet you own; receives test-SOL only
FEE_WALLET_ADDRESS=YOUR_DEV_FEE_WALLET_PUBLIC_KEY

# App URL — for devnet webhook callbacks use ngrok or similar tunnel
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Pinata — uploads land on real IPFS even in devnet; use a test API key if preferred
PINATA_JWT=YOUR_PINATA_JWT

# Local Postgres — use a separate DB for tests to avoid polluting production data
DATABASE_URL=postgresql://user:password@localhost:5432/solana_token_test
PG_POOL_MAX=5

# Local Redis
REDIS_URL=redis://localhost:6379

# Cron secret — any value for local testing
CRON_SECRET=devnet-cron-secret-replace-me

# Birdeye — devnet support is limited; some endpoints return empty data
BIRDEYE_API_KEY=YOUR_BIRDEYE_API_KEY
