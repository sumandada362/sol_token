# Copy to .env.local and fill in values. NEVER commit .env.local.

# ── Solana RPC ─────────────────────────────────────────────────────────────
# Server-side RPC — has API key, NEVER expose to browser
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=d38d9e94-7b1b-420d-9761-be347fc0570a

# Public RPC used by the browser wallet adapter (no secret key)
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
# Set to mainnet-beta for production
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# ── Helius (Phase 2) ───────────────────────────────────────────────────────
# Used server-side for DAS getTokenAccounts and webhook registration
HELIUS_API_KEY=d38d9e94-7b1b-420d-9761-be347fc0570a

# Shared secret sent by Helius in every webhook POST (Authorization header).
# Generate with: openssl rand -hex 32
WEBHOOK_AUTH_SECRET=YOUR_RANDOM_32_BYTE_HEX

# ── Birdeye (Phase 2) ──────────────────────────────────────────────────────
# Server-side only — for price, volume, liquidity, OHLCV data
BIRDEYE_API_KEY=YOUR_BIRDEYE_API_KEY

# ── App URL ────────────────────────────────────────────────────────────────
# Full origin — used to build the Helius webhook callback URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Fee wallet ─────────────────────────────────────────────────────────────
# PUBLIC KEY ONLY. Private key lives in a hardware wallet, never here.
FEE_WALLET_ADDRESS=mgh8Y7Q9a9JdEADC3M7RmSRo5f51Y34UjoqZPyqFV1x

# ── IPFS ───────────────────────────────────────────────────────────────────
PINATA_JWT=YOUR_PINATA_JWT

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname
PG_POOL_MAX=10

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Cron security (Phase 2) ────────────────────────────────────────────────
# Vercel cron calls include this as Bearer token. Generate with: openssl rand -hex 32
CRON_SECRET=YOUR_RANDOM_32_BYTE_HEX
